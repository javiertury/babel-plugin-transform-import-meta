{
  "name": "babel-plugin-transform-import-meta",
  "version": "3.0.0",
  "description": "Transforms import.meta for nodejs environments",
  "repository": {
    "type": "git",
    "url": "https://github.com/javiertury/babel-plugin-transform-import-meta"
  },
  "license": "BSD-3-Clause",
  "author": "Javier Garcia <javiertury@gmail.com>",
  "keywords": [
    "babel-plugin",
    "import-meta"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "lib"
  ],
  "type": "commonjs",
  "main": "lib/index.js",
  "module": "lib/index.esm.mjs",
  "exports": {
    "require": "./lib/index.js",
    "import": "./lib/index.esm.mjs"
  },
  "types": "lib/index.d.ts",
  "scripts": {
    "prepare": "simple-git-hooks",
    "clean": "rimraf lib",
    "build": "rollup -c rollup.config.mjs",
    "lint": "eslint --max-warnings=0 .",
    "test": "vitest run",
    "prepack": "pnpm run lint && pnpm run clean && pnpm run build",
    "prepublishOnly": "pnpm run test",
    "release": "commit-and-tag-version"
  },
  "dependencies": {
    "@babel/template": "^8.0.0",
    "tslib": "^2.8.1"
  },
  "peerDependencies": {
    "@babel/core": "^8.0.1"
  },
  "devDependencies": {
    "@babel/cli": "^8.0.1",
    "@babel/core": "^8.0.1",
    "@babel/types": "^8.0.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@types/babel__core": "^7.20.5",
    "@types/babel__template": "^7.4.4",
    "commit-and-tag-version": "^12.7.1",
    "eslint": "^10.1.0",
    "eslint-config-love": "^151.0.0",
    "lint-staged": "^15.3.0",
    "rimraf": "^6.1.3",
    "rollup": "^4.29.1",
    "rollup-plugin-typescript2": "^0.37.0",
    "simple-git-hooks": "^2.11.1",
    "ts-dedent": "^2.2.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.ts": "eslint"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged",
    "commit-msg": "pnpm exec commitlint -e"
  }
}
